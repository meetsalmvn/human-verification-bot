# ==============================================================
# Human Verification Telegram Bot — environment configuration
# Copy this file to ".env" and fill in real values for local dev.
# On Northflank, set these as environment variables in the service.
# ==============================================================

# --- Telegram ---
# Token from @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Comma-separated list of Telegram user IDs allowed to use admin commands
ADMIN_IDS=111111111,222222222

# The numeric chat ID of the private group this bot protects
# (e.g. -1001234567890). The bot must be an admin in that group with
# permission to approve/decline join requests.
GROUP_ID=-1001234567890

# Public username of the bot (without @), used to build deep links
BOT_USERNAME=YourVerificationBot

# --- Webhook (recommended for Northflank / production) ---
USE_WEBHOOK=true
# Public HTTPS base URL of your deployed service, no trailing slash
WEBHOOK_HOST=https://your-app.northflank.app
WEBHOOK_PATH=/webhook
# Optional secret Telegram will echo back on every request; leave blank to disable
WEBHOOK_SECRET=change-me-to-a-random-string

# Host/port the aiohttp server binds to inside the container
WEBAPP_HOST=0.0.0.0
PORT=8080

# --- Database ---
DB_PATH=/app/data/bot.db

# --- Verification defaults (overridable at runtime via /config) ---
VERIFICATION_TIMEOUT=60
MAX_ATTEMPTS=3
DEFAULT_CHALLENGE_TYPE=random

# --- Security ---
RATE_LIMIT_WINDOW_SECONDS=1.0

# --- Misc ---
LOG_LEVEL=INFO
MAINTENANCE_MODE=false
